<%- include("partials/header") %>

<section class="page-head">
  <h1>Receipts</h1>
  <p class="muted">Snap a receipt — MoneyTree reads it, categorizes it, and learns your habits.</p>
</section>

<div class="two-col">
  <section class="card">
    <h2>Upload a receipt</h2>
    <p class="muted">On your phone this opens the camera. Clear, well-lit photos read best.</p>
    <form action="/receipts/upload" method="POST" enctype="multipart/form-data" class="stacked-form">
      <label>
        Receipt photo
        <input type="file" name="receipt" accept="image/*" capture="environment" required />
      </label>
      <button type="submit" class="btn btn-primary">📸 Upload &amp; read</button>
    </form>
    <p class="muted" style="margin-top: 0.75rem;">
      After reading, you'll review what was found before it's saved as an expense.
    </p>
  </section>

  <section class="card">
    <h2>Your receipts</h2>
    <% if (receipts.length === 0) { %>
      <p class="empty-state">No receipts yet — upload your first one.</p>
    <% } else { %>
      <ul class="tx-list">
        <% receipts.forEach((r) => { %>
          <li class="tx-row">
            <a href="/receipts/<%= r.id %>/image" target="_blank" class="receipt-thumb-link" title="View photo">🧾</a>
            <span class="tx-meta">
              <strong><%= r.merchant || "Unknown merchant" %></strong>
              <small class="muted">
                <%= r.purchased_on ? formatDate(r.purchased_on) : "No date" %>
                <%= r.category_name ? " · " + r.category_icon + " " + r.category_name : "" %>
                · <%= (r.items || []).length %> item<%= (r.items || []).length === 1 ? "" : "s" %>
              </small>
            </span>
            <span class="tx-amount negative">
              <%= r.total != null ? money(r.total) : "—" %>
            </span>
            <% if (r.transaction_id) { %>
              <span class="badge badge-done">saved</span>
            <% } else { %>
              <a href="/receipts/<%= r.id %>/review" class="btn btn-ghost btn-sm">Review</a>
            <% } %>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </section>
</div>

<%- include("partials/footer") %>
