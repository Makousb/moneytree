# Copy this file to .env and fill in real values. Never commit .env.

# --- App ---
NODE_ENV=development
# 3001 by default so it can run next to other local apps on 3000.
PORT=3001
# Required in production; any random long string works in development.
SESSION_SECRET=change-me-to-a-long-random-string

# --- Analytics service (Python/FastAPI) ---
# The Node app calls this for the Reports page. If the service is down,
# Reports degrades gracefully and the rest of the app is unaffected.
ANALYTICS_URL=http://localhost:8000

# --- PostgreSQL ---
# Hosted platforms (Render/Heroku/Railway) can supply a single DATABASE_URL
# instead of the discrete DB_* values below; it takes precedence when set.
# DATABASE_URL=postgres://user:password@host:5432/moneytree
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=moneytree
DB_SSL=false
